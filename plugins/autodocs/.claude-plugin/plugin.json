{
  "name": "autodocs",
  "version": "0.1.0",
  "description": "Generate and maintain durable repository documentation with OpenHands, with optional GitNexus enrichment",
  "author": {
    "name": "Rajiv Shah"
  },
  "homepage": "https://github.com/rajshah4/openhands-autodocs",
  "repository": "https://github.com/rajshah4/openhands-autodocs",
  "license": "MIT",
  "keywords": [
    "documentation",
    "repo",
    "wiki",
    "automation",
    "openhands",
    "gitnexus"
  ],
  "parameters": {
    "focus": {
      "type": "string",
      "description": "Optional area of the repository to prioritize while generating or updating docs",
      "required": false,
      "default": "repository architecture, workflows, and future agent guidance"
    }
  },
  "entry_command": "plan",
  "examples": [
    {
      "title": "Plan documentation",
      "prompt": "/autodocs:plan",
      "parameters": {
        "focus": "architecture and workflows"
      }
    },
    {
      "title": "Initialize documentation",
      "prompt": "/autodocs:init",
      "parameters": {
        "focus": "architecture and workflows"
      }
    },
    {
      "title": "Update existing documentation",
      "prompt": "/autodocs:update API and routing changes",
      "parameters": {
        "focus": "API and routing changes"
      }
    }
  ]
}
